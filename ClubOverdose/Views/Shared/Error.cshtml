@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<section class="page-header">
    <div class="container">
        <h1>Something Went Wrong</h1>
        <p>An error occurred while processing your request.</p>
    </div>
</section>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="form-card">
                <h3 class="mb-3 text-white">We could not complete that action.</h3>
                <p class="menu-meta mb-4">
                    Please try again in a moment. If the issue keeps happening, use the request ID below when asking for support.
                </p>

                @if (Model.ShowRequestId)
                {
                    <div class="drink-detail-row">
                        <span class="drink-label">Request ID</span>
                        <span class="drink-value"><code>@Model.RequestId</code></span>
                    </div>
                }

                <div class="d-flex gap-2 flex-wrap mt-4">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-neon">Back Home</a>
                    <a asp-controller="Home" asp-action="Contacts" class="btn btn-outline-light">Contact Us</a>
                </div>
            </div>
        </div>
    </div>
</div>
