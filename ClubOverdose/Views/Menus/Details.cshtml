@model ClubOverdose.Data.Menu

@{
    ViewData["Title"] = "Menu Details";
    var isSuperAdmin = User.IsInRole("SuperAdmin");
}

<section class="page-header">
    <div class="container">
        <h1>Menu Details</h1>
        <p>Review this menu category.</p>
    </div>
</section>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="form-card">
                <h3 class="mb-4 text-white">Menu</h3>

                <div class="drink-detail-row">
                    <span class="drink-label">@Html.DisplayNameFor(model => model.Name)</span>
                    <span class="drink-value">@Html.DisplayFor(model => model.Name)</span>
                </div>

                <div class="d-flex gap-2 flex-wrap mt-4">
                    @if (isSuperAdmin)
                    {
                        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">Edit</a>
                    }
                    <a asp-action="Index" class="btn btn-outline-light">Back to List</a>
                </div>
            </div>
        </div>
    </div>
</div>
