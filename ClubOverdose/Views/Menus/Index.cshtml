@model IEnumerable<ClubOverdose.Data.Menu>

@{
    ViewData["Title"] = "Menus";
    var isSuperAdmin = User.IsInRole("SuperAdmin");
    var menus = Model.ToList();
}

<section class="page-header">
    <div class="container">
        <h1>Menus</h1>
        <p>Manage the menu collections that organize drinks across the club.</p>
    </div>
</section>

<div class="container pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <h2 class="text-white m-0">Menu Collections</h2>
        @if (isSuperAdmin)
        {
            <a asp-action="Create" class="btn btn-neon">Create New Menu</a>
        }
    </div>

    @if (!menus.Any())
    {
        <div class="form-card">
            <p class="menu-meta mb-0">No menu collections have been added yet.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in menus)
            {
                <div class="col-md-6 col-xl-4">
                    <div class="menu-card">
                        <div class="menu-card-body">
                            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                <div>
                                    <p class="menu-meta mb-1">Club menu</p>
                                    <h3 class="mb-0">@Html.DisplayFor(modelItem => item.Name)</h3>
                                </div>
                                <span class="menu-price">Menu</span>
                            </div>

                            <div class="d-flex gap-2 flex-wrap mt-4">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light">Details</a>
                                @if (isSuperAdmin)
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
