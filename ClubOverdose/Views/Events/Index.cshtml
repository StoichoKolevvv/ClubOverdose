@model IEnumerable<ClubOverdose.Data.Event>

@{
    ViewData["Title"] = "Events";
    var isSuperAdmin = User.IsInRole("SuperAdmin");
    var fromDate = ViewData["FromDate"] as string;
    var toDate = ViewData["ToDate"] as string;
}

<section class="page-header">
    <div class="container">
        <h1>Events</h1>
        <p>Discover upcoming parties and unforgettable nights.</p>
    </div>
</section>

<div class="container pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white m-0">All Events</h2>
        @if (isSuperAdmin)
        {
            <a asp-action="Create" class="btn btn-neon">Create New Event</a>
        }
    </div>

    <div class="form-card mb-5">
        <form asp-action="Index" method="get" class="custom-form">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label for="fromDate" class="form-label">From date</label>
                    <input id="fromDate" name="fromDate" type="date" class="form-control" value="@fromDate" />
                </div>

                <div class="col-md-4">
                    <label for="toDate" class="form-label">To date</label>
                    <input id="toDate" name="toDate" type="date" class="form-control" value="@toDate" />
                </div>

                <div class="col-md-2">
                    <button type="submit" class="btn btn-neon w-100">Filter</button>
                </div>

                <div class="col-md-2">
                    <a asp-action="Index" class="btn btn-outline-light w-100">Clear</a>
                </div>
            </div>
        </form>
    </div>

    @if (!Model.Any())
    {
        <div class="form-card">
            <p class="menu-meta mb-0">No events match the selected dates.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
        @foreach (var item in Model)
        {
            var desc = item.Description ?? "";

            desc = System.Text.RegularExpressions.Regex.Replace(
            desc,
            @"https?:\/\/[^\s]+",
            ""
            ).Trim();

            if (string.IsNullOrWhiteSpace(desc))
            {
                desc = "No description available for this event.";
            }

            <div class="col-md-4">
                <div class="event-card">
                    <div class="event-image">
                        <img src="@(string.IsNullOrEmpty(item.ImageUrl)
                                                         ? "https://images.unsplash.com/photo-1514525253161-7a46d19cd819?auto=format&fit=crop&w=800&q=80"
                                                         : item.ImageUrl)" alt="@item.Name" />

                    <div class="event-date">
                        @item.EventDateTime.ToString("dd MMM")
                    </div>
                </div>

                    <div class="event-body">
                        <h3>
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-white text-decoration-none">
                                @item.Name
                            </a>
                        </h3>

                        <p class="event-description">
                            @(desc.Length > 100 ? desc.Substring(0, 100) + "..." : desc)
                        </p>

                        <div class="event-info mb-2">
                            <span>🕒 @item.EventDateTime.ToString("dd MMM yyyy, HH:mm")</span>
                        </div>

                        <div class="event-info mb-3">
                            <small class="text-light">
                                Updated: @item.LastUpdatedDate.ToString("dd MMM yyyy")
                            </small>
                        </div>

                        <div class="d-flex gap-2 flex-wrap">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light">Details</a>
                            @if (isSuperAdmin)
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
                }
        </div>
    }
</div>
