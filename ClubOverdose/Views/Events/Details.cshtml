@model ClubOverdose.Data.Event

@{
    ViewData["Title"] = "Event Details";
    var description = Model.Description ?? "";
    string? videoId = null;

    var match = System.Text.RegularExpressions.Regex.Match(
        description,
        @"(?:youtube\.com\/watch\?v=|youtube\.com\/shorts\/|youtu\.be\/)([A-Za-z0-9_-]+)",
        System.Text.RegularExpressions.RegexOptions.IgnoreCase
    );

    if (match.Success)
    {
        videoId = match.Groups[1].Value;
        description = System.Text.RegularExpressions.Regex.Replace(
            description,
            @"https?:\/\/[^\s]+",
            ""
        ).Trim();
    }
}

<section class="page-header">
    <div class="container">
        <h1>@Model.Name</h1>
        <p>@Model.EventDateTime.ToString("dd MMMM yyyy - HH:mm")</p>
    </div>
</section>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="form-card">
                <div class="event-image mb-4">
                    <img src="@(string.IsNullOrEmpty(Model.ImageUrl)
                                      ? "https://images.unsplash.com/photo-1506157786151-b8491531f063?auto=format&fit=crop&w=1600&q=80"
                                      : Model.ImageUrl)"
                         alt="@Model.Name" />
                    <div class="event-date">
                        @Model.EventDateTime.ToString("dd MMM")
                    </div>
                </div>

                <h3 class="mb-3 text-white">About Event</h3>

                @if (!string.IsNullOrWhiteSpace(description))
                {
                    <p class="menu-meta">@description</p>
                }
                else
                {
                    <p class="menu-meta">No description available for this event.</p>
                }

                @if (!string.IsNullOrEmpty(videoId))
                {
                    <div class="mt-4">
                        <iframe class="w-100 rounded"
                                height="350"
                                src="https://www.youtube-nocookie.com/embed/@videoId"
                                title="Event video"
                                frameborder="0"
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                allowfullscreen>
                        </iframe>
                    </div>
                }

                <div class="mt-4">
                    <div class="drink-detail-row">
                        <span class="drink-label">Date</span>
                        <span class="drink-value">@Model.EventDateTime.ToString("f")</span>
                    </div>

                    <div class="drink-detail-row">
                        <span class="drink-label">Last Update</span>
                        <span class="drink-value">@Model.LastUpdatedDate.ToString("dd MMM yyyy")</span>
                    </div>
                </div>

                <div class="d-flex gap-2 flex-wrap mt-4">
                    <a asp-controller="Reservations"
                       asp-action="Create"
                       asp-route-eventId="@Model.Id"
                       class="btn btn-neon">
                        Book This Event
                    </a>

                    <a asp-action="Edit"
                       asp-route-id="@Model.Id"
                       class="btn btn-outline-light">
                        Edit Event
                    </a>

                    <a asp-action="Index"
                       class="btn btn-secondary">
                        Back to Events
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
