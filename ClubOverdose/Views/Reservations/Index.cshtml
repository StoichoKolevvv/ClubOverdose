@model ClubOverdose.Models.ReservationsIndexViewModel

@{
    ViewData["Title"] = "Reservations";
    var isEventDashboard = Model.IsSuperAdmin && Model.SelectedEventId == null;
    var pageSubtitle = isEventDashboard
        ? "Choose an event to review its reservations."
        : "Manage booked spots for upcoming NightSheng nights.";
    var listTitle = Model.IsSuperAdmin && Model.SelectedEventId != null
        ? $"Reservations for {Model.SelectedEventName}"
        : "My Reservations";
}

<section class="page-header">
    <div class="container">
        <h1>Reservations</h1>
        <p>@pageSubtitle</p>
    </div>
</section>

<div class="container pb-5">
    @if (isEventDashboard)
    {
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <h2 class="text-white m-0">Events</h2>
            <a asp-action="Create" class="btn btn-neon">Create New</a>
        </div>

        @if (!Model.Events.Any())
        {
            <div class="form-card">
                <p class="menu-meta mb-0">No events are available yet.</p>
            </div>
        }

        <div class="row g-4">
            @foreach (var item in Model.Events)
            {
                <div class="col-md-6 col-xl-4">
                    <div class="event-card">
                        <div class="event-body">
                            <h3 class="text-white">@item.Event.Name</h3>

                            <div class="event-info mb-3">
                                @item.Event.EventDateTime.ToString("dd MMM yyyy, HH:mm")
                            </div>

                            <p class="event-description">
                                @item.ReservationCount @(item.ReservationCount == 1 ? "reservation" : "reservations")
                            </p>

                            <a asp-action="Index" asp-route-eventId="@item.Event.Id" class="btn btn-neon">
                                View Reservations
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
            <div>
                <h2 class="text-white m-0">@listTitle</h2>
                @if (Model.SelectedEventDateTime.HasValue)
                {
                    <p class="event-info mt-2 mb-0">
                        @Model.SelectedEventDateTime.Value.ToString("dd MMM yyyy, HH:mm")
                    </p>
                }
            </div>

            <div class="d-flex gap-2 flex-wrap">
                @if (Model.IsSuperAdmin)
                {
                    <a asp-action="Index" class="btn btn-outline-light">Back to Events</a>
                    <a asp-action="Create" asp-route-eventId="@Model.SelectedEventId" class="btn btn-neon">Create New</a>
                }
                else
                {
                    <a asp-action="Create" class="btn btn-neon">Create New</a>
                }
            </div>
        </div>

        @if (!Model.Reservations.Any())
        {
            <div class="form-card">
                <p class="menu-meta mb-0">No reservations found.</p>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var item in Model.Reservations)
                {
                    var clientLabel = item.Client != null ? item.Client.Id : item.ClientId;
                    var eventLabel = item.Event != null ? item.Event.Name : item.EventId.ToString();

                    <div class="col-md-6 col-xl-4">
                        <div class="menu-card">
                            <div class="menu-card-body">
                                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                    <div>
                                        <h3 class="mb-1">@eventLabel</h3>
                                        <p class="menu-meta mb-0">@item.ReservationDate.ToString("dd MMM yyyy, HH:mm")</p>
                                    </div>
                                    <span class="menu-price">@item.NumberOfGuests guests</span>
                                </div>

                                <div class="drink-detail-row">
                                    <span class="drink-label">Client</span>
                                    <span class="drink-value">@clientLabel</span>
                                </div>

                                <div class="drink-detail-row">
                                    <span class="drink-label">Event</span>
                                    <span class="drink-value">@eventLabel</span>
                                </div>

                                <div class="d-flex gap-2 flex-wrap mt-4">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light">Details</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>
