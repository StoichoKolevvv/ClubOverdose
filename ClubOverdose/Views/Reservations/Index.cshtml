@model IEnumerable<ClubOverdose.Data.Reservation>

@{
    ViewData["Title"] = "Reservations";
}

<section class="page-header">
    <div class="container">
        <h1>Reservations</h1>
        <p>Manage booked spots for upcoming ClubOverdose nights.</p>
    </div>
</section>

<div class="container pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <h2 class="text-white m-0">All Reservations</h2>
        <a asp-action="Create" class="btn btn-neon">Create New</a>
    </div>

    <div class="form-card">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>
                            @Html.DisplayNameFor(model => model.Client)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Event)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.NumberOfGuests)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.ReservationDate)
                        </th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.Client.Id)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Event.Id)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.NumberOfGuests)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.ReservationDate)
                            </td>
                            <td>
                                <div class="d-flex justify-content-end gap-2 flex-wrap">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light">Details</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
