@model ClubOverdose.Data.Reservation

@{
    ViewData["Title"] = "Delete Reservation";
}

<section class="page-header">
    <div class="container">
        <h1>Delete Reservation</h1>
        <p>Review this reservation before removing it.</p>
    </div>
</section>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="form-card">
                <h3 class="mb-4 text-danger">Delete Confirmation</h3>

                <div class="drink-detail-row">
                    <span class="drink-label">@Html.DisplayNameFor(model => model.Client)</span>
                    <span class="drink-value">@Html.DisplayFor(model => model.Client.Id)</span>
                </div>

                <div class="drink-detail-row">
                    <span class="drink-label">@Html.DisplayNameFor(model => model.Event)</span>
                    <span class="drink-value">@Html.DisplayFor(model => model.Event.Id)</span>
                </div>

                <div class="drink-detail-row">
                    <span class="drink-label">@Html.DisplayNameFor(model => model.NumberOfGuests)</span>
                    <span class="drink-value">@Html.DisplayFor(model => model.NumberOfGuests)</span>
                </div>

                <div class="drink-detail-row">
                    <span class="drink-label">@Html.DisplayNameFor(model => model.ReservationDate)</span>
                    <span class="drink-value">@Html.DisplayFor(model => model.ReservationDate)</span>
                </div>

                <form asp-action="Delete" class="mt-4">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2 flex-wrap">
                        <input type="submit" value="Delete" class="btn btn-danger" />
                        <a asp-action="Index" class="btn btn-outline-light">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
