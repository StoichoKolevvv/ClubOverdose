@model ClubOverdose.Data.Type

@{
    ViewData["Title"] = "Edit Type";
}

<section class="page-header">
    <div class="container">
        <h1>Edit Type</h1>
        <p>Update the selected drink type.</p>
    </div>
</section>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="form-card">
                <h3 class="text-white mb-4">Type Information</h3>

                <form asp-action="Edit" class="custom-form">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" placeholder="Cocktails, Soft Drinks, Alcohol..." />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2 flex-wrap mt-4">
                        <button type="submit" class="btn btn-neon">Save Changes</button>
                        <a asp-action="Index" class="btn btn-outline-light">Back to Types</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
