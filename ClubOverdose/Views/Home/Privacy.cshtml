@{
    ViewData["Title"] = "Privacy Policy";
}

<section class="page-header">
    <div class="container">
        <h1>Privacy Policy</h1>
        <p>How NightSheng handles account and reservation information.</p>
    </div>
</section>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="form-card">
                <h3 class="mb-3 text-white">Your Data</h3>
                <p class="menu-meta">
                    NightSheng uses account and reservation details only to support sign in,
                    event bookings and customer service.
                </p>

                <div class="drink-detail-row">
                    <span class="drink-label">Account</span>
                    <span class="drink-value">Used for secure login and reservation ownership.</span>
                </div>

                <div class="drink-detail-row">
                    <span class="drink-label">Reservations</span>
                    <span class="drink-value">Used to manage event bookings and guest counts.</span>
                </div>

                <div class="drink-detail-row">
                    <span class="drink-label">Contact</span>
                    <span class="drink-value">Used only when we need to respond to your request.</span>
                </div>
            </div>
        </div>
    </div>
</div>
