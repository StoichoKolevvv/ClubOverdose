@{
    ViewData["Title"] = "About Us";
}

<section class="page-hero small-hero">
    <div class="page-overlay"></div>

    <div class="container page-content">
        <h1>About <span>ClubOverdose</span></h1>
        <p>
            ClubOverdose is the place where music, lights and unforgettable nights meet.
            We create premium nightlife experiences with top DJs, modern atmosphere and exclusive events.
        </p>
    </div>
</section>

<section class="info-section">
    <div class="container">
        <div class="row g-4 align-items-center">
            <div class="col-md-6">
                <h2>Our Story</h2>
                <p>
                    Born from the love of music and nightlife, ClubOverdose brings people together
                    for nights full of energy, rhythm and memories.
                </p>
                <p>
                    From themed parties to live DJ sets, every event is designed to give you a
                    unique club experience.
                </p>
            </div>

            <div class="col-md-6">
                <div class="glass-card">
                    <h3>What We Offer</h3>
                    <ul>
                        <li>Top local and international DJs</li>
                        <li>Premium VIP reservations</li>
                        <li>Modern lighting and sound</li>
                        <li>Exclusive weekly events</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>
