@{
    ViewData["Title"] = "Contacts";
}

<section class="page-hero small-hero">
    <div class="page-overlay"></div>

    <div class="container page-content">
        <h1>Contact <span>Us</span></h1>
        <p>Have questions about events, reservations or VIP tables? Get in touch with us.</p>
    </div>
   
</section>

<section class="info-section">
    <div class="container contact-layout">

        <div class="contact-grid">

            <!-- LEFT: Info + Map -->
            <div class="glass-card">
                <h3>Club Information</h3>

                <p><strong>Address:</strong> Sofia, Bulgaria</p>
                <p><strong>Phone:</strong> +359 888 123 456</p>
                <p><strong>Email:</strong> info@cluboverdose.bg</p>
                <p><strong>Working Hours:</strong> Friday - Sunday, 22:00 - 05:00</p>

                <hr class="divider" />

                <h4>Find Us</h4>

                <div class="map-container">
                    <iframe src="https://www.google.com/maps?q=Sofia%20Bulgaria&hl=en&output=embed"
                            width="100%"
                            height="300"
                            style="border:0;"
                            allowfullscreen=""
                            loading="lazy">
                    </iframe>
                </div>
            </div>

            <!-- RIGHT: Form -->
            <div class="glass-card">
                <h3>Send us a message</h3>

                <form>
                    <div class="mb-3">
                        <input type="text" class="form-control custom-input" placeholder="Your name">
                    </div>

                    <div class="mb-3">
                        <input type="email" class="form-control custom-input" placeholder="Your email">
                    </div>

                    <div class="mb-3">
                        <textarea class="form-control custom-input" rows="5" placeholder="Your message"></textarea>
                    </div>

                    <button type="submit" class="btn btn-neon">Send Message</button>
                </form>
                <div class="contact-faq">
                    <h5>Quick Questions</h5>

                    

                    <p>
                        <strong>Is there a dress code?</strong><br>
                        Yes – smart casual / club style.
                    </p>

                    <p>
                        <strong>What time do events start?</strong><br>
                        Usually after 22:00.
                    </p>
                </div>
            </div>

        </div>

    </div>
</section>
