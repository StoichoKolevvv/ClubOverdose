@model ClubOverdose.Data.Drink

@{
    ViewData["Title"] = "Edit Drink";
}

<section class="page-header">
    <div class="container">
        <h1>Edit Drink</h1>
        <p>Update the selected drink.</p>
    </div>
</section>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="form-card">
                <form asp-action="Edit" class="custom-form">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="TypeId" class="form-label"></label>
                        <select asp-for="TypeId" class="form-select" asp-items="ViewBag.TypeId"></select>
                        <span asp-validation-for="TypeId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MenuId" class="form-label"></label>
                        <select asp-for="MenuId" class="form-select" asp-items="ViewBag.MenuId"></select>
                        <span asp-validation-for="MenuId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Price" class="form-label"></label>
                        <input asp-for="Price" class="form-control" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Volume" class="form-label"></label>
                        <input asp-for="Volume" class="form-control" />
                        <span asp-validation-for="Volume" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2 flex-wrap mt-4">
                        <button type="submit" class="btn btn-primary">Save</button>
                        <a asp-action="Index" class="btn btn-outline-light">Back to Menu</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
