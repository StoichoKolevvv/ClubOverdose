@model IEnumerable<ClubOverdose.Data.Drink>

@{
    ViewData["Title"] = "Menu";
    var isSuperAdmin = User.IsInRole("SuperAdmin");
    var searchTerm = ViewData["SearchTerm"] as string;
    var minPrice = ViewData["MinPrice"] as string;
    var maxPrice = ViewData["MaxPrice"] as string;
    var groupedMenus = Model
        .OrderBy(d => d.Menu != null ? d.Menu.Name : "Other Menu")
        .ThenBy(d => d.Types != null ? d.Types.Name : "Other")
        .ThenBy(d => d.Name)
        .GroupBy(d => new { d.MenuId, Name = d.Menu != null ? d.Menu.Name : "Other Menu" });
}

<section class="page-header">
    <div class="container">
        <h1>Menu</h1>
        <p>Discover our premium drinks and club favorites.</p>
    </div>
</section>

<div class="container pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white m-0">Drinks Menu</h2>
        @if (isSuperAdmin)
        {
            <a asp-action="Create" class="btn btn-neon">Add Drink</a>
        }
    </div>

    <div class="form-card mb-5">
        <form asp-action="Index" method="get" class="custom-form">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label for="searchTerm" class="form-label">Search drink</label>
                    <input id="searchTerm" name="searchTerm" class="form-control" value="@searchTerm" placeholder="Mojito, whiskey, cola..." />
                </div>

                <div class="col-md-3">
                    <label for="menuId" class="form-label">Menu</label>
                    <select id="menuId" name="menuId" class="form-select" asp-items="ViewBag.MenuFilterItems">
                        <option value="">All menus</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label for="typeId" class="form-label">Type</label>
                    <select id="typeId" name="typeId" class="form-select" asp-items="ViewBag.TypeFilterItems">
                        <option value="">All types</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <button type="submit" class="btn btn-neon w-100">Search</button>
                </div>
            </div>

            <div class="row g-3 align-items-end mt-1">
                <div class="col-md-3">
                    <label for="minPrice" class="form-label">Min price</label>
                    <input id="minPrice" name="minPrice" type="number" step="0.01" min="0" class="form-control" value="@minPrice" placeholder="0" />
                </div>

                <div class="col-md-3">
                    <label for="maxPrice" class="form-label">Max price</label>
                    <input id="maxPrice" name="maxPrice" type="number" step="0.01" min="0" class="form-control" value="@maxPrice" placeholder="50" />
                </div>

                <div class="col-md-3">
                    <a asp-action="Index" class="btn btn-outline-light w-100">Clear filters</a>
                </div>
            </div>
        </form>
    </div>

    @if (!groupedMenus.Any())
    {
        <div class="menu-card">
            <div class="menu-card-body">
                <p class="menu-meta mb-0">No drinks match the selected filters.</p>
            </div>
        </div>
    }

    @foreach (var menuGroup in groupedMenus)
    {
        <div class="menu-section mb-5">
            <div class="menu-section-header mb-4">
                <h2>@menuGroup.Key.Name</h2>
            </div>

            @foreach (var typeGroup in menuGroup
                    .OrderBy(d => d.Types != null ? d.Types.Name : "Other")
                    .ThenBy(d => d.Name)
                    .GroupBy(d => new { d.TypeId, Name = d.Types != null ? d.Types.Name : "Other" }))
            {
                <div class="mb-4">
                    <h3 class="text-white mb-3">@typeGroup.Key.Name</h3>

                    <div class="row g-3">
                        @foreach (var item in typeGroup)
                        {
                            <div class="col-sm-6 col-lg-4 col-xl-3">
                                <div class="menu-card">
                                    <div class="menu-card-body">
                                        <h4 class="text-white mb-2">@item.Name</h4>
                                        <p class="menu-meta mb-3">@item.Volume ml</p>

                                        <span class="menu-price">@item.Price.ToString("0.##") лв.</span>

                                        @if (isSuperAdmin)
                                        {
                                            <div class="d-flex gap-2 flex-wrap mt-3">
                                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light">Details</a>
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit</a>
                                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>
