@model ClubOverdose.Data.Drink

@{
    ViewData["Title"] = "Drink Details";
}

<section class="page-header">
    <div class="container">
        <h1>Drink Details</h1>
        <p>View information about this drink.</p>
    </div>
</section>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="form-card">
                <h3 class="mb-4">@Model.Name</h3>

                <div class="drink-detail-row">
                    <span class="drink-label">Price</span>
                    <span class="drink-value">@Model.Price.ToString("0.00") лв.</span>
                </div>

                <div class="drink-detail-row">
                    <span class="drink-label">Volume</span>
                    <span class="drink-value">@Model.Volume ml</span>
                </div>

                @if (Model.Types != null)
                {
                    <div class="drink-detail-row">
                        <span class="drink-label">Type</span>
                        <span class="drink-value">@Model.Types.Name</span>
                    </div>
                }

                @if (Model.Menu != null)
                {
                    <div class="drink-detail-row">
                        <span class="drink-label">Menu</span>
                        <span class="drink-value">@Model.Menu.Name</span>
                    </div>
                }

                <div class="drink-detail-row">
                    <span class="drink-label">Date Added</span>
                    <span class="drink-value">@Model.DateAdded.ToString("dd MMM yyyy")</span>
                </div>

                <div class="d-flex gap-2 flex-wrap mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
                    <a asp-action="Index" class="btn btn-outline-light">Back to Menu</a>
                </div>
            </div>
        </div>
    </div>
</div>
