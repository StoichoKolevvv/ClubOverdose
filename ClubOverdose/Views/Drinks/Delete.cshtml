@model ClubOverdose.Data.Drink

@{
    ViewData["Title"] = "Delete Drink";
}

<section class="page-header">
    <div class="container">
        <h1>Delete Drink</h1>
        <p>Are you sure you want to delete this drink?</p>
    </div>
</section>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="form-card">
                <h3 class="mb-4 text-danger">Delete Confirmation</h3>

                <div class="drink-detail-row">
                    <span class="drink-label">Name</span>
                    <span class="drink-value">@Model.Name</span>
                </div>

                <div class="drink-detail-row">
                    <span class="drink-label">Price</span>
                    <span class="drink-value">@Model.Price.ToString("0.00") лв.</span>
                </div>

                <div class="drink-detail-row">
                    <span class="drink-label">Volume</span>
                    <span class="drink-value">@Model.Volume ml</span>
                </div>

                @if (Model.Types != null)
                {
                    <div class="drink-detail-row">
                        <span class="drink-label">Type</span>
                        <span class="drink-value">@Model.Types.Name</span>
                    </div>
                }

                <form asp-action="Delete" class="mt-4">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2 flex-wrap">
                        <input type="submit" value="Delete" class="btn btn-danger" />
                        <a asp-action="Index" class="btn btn-outline-light">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>